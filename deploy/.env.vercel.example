# Reflex env vars (Next.js app). Copy to .env.local for dev; set the same in the Vercel
# dashboard (or via `vercel env add`) for deploys. Anything NOT NEXT_PUBLIC_ is server-only.

# --- App ---
NEXT_PUBLIC_APP_URL=

# --- InsForge (backend: Postgres, storage, realtime) ---
# from `npx @insforge/cli metadata`
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
INSFORGE_SERVICE_KEY=

# --- Model access (diagnosis + screenshot/vision) ---
# Vercel AI Gateway: one key, many providers, auto-failover, $5/30-day free.
# On a Vercel deployment you can use OIDC instead and omit this.
AI_GATEWAY_API_KEY=

# --- GitHub (PR creation) ---
GITHUB_TOKEN=
GITHUB_REPO=

# --- Replicas (agent dispatch) — fill once the org admin redeems `ainexus` ---
REPLICAS_API_KEY=
