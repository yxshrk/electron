# Reflex environment. Copy to .env.local and fill in.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Slack slice (Laurence): backend toggle.
# "mock" uses the in-memory scripted backend; any other value hits the real /api/runs routes.
REFLEX_BACKEND=mock

# Two-gate UX (team decision): backend stops at `diagnosed` instead of auto-dispatching.
# The user then clicks "🚀 Approve & dispatch fix" in Slack to trigger reproduce→fix→PR.
# Set to anything other than "false" (or unset) for the one-Confirm auto-cascade instead.
REFLEX_AUTO_DISPATCH=false

# InsForge (Yash) - from `npx @insforge/cli current` / .insforge/project.json
INSFORGE_PROJECT_URL=https://<appkey>.<region>.insforge.app
INSFORGE_SERVICE_KEY=<insforge-service-key>

# Model access - InsForge can provision this with:
# npx @insforge/cli ai setup --env-file .env.local
# Used for frame vision and embeddings.
# Without it, diagnosis falls back to deterministic fixtures and grounding returns empty.
OPENROUTER_API_KEY=<openrouter-api-key>
# Optional model overrides:
REFLEX_VISION_MODEL=openai/gpt-4o-mini
REFLEX_EMBED_MODEL=openai/text-embedding-3-small

# Slack (Laurence)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Replicas + GitHub (Luke)
DEFAULT_GITHUB_REPO=https://github.com/yxshrk/electron
GITHUB_TOKEN=
GITHUB_BASE_BRANCH=main
# Optional local override. Vercel automatically uses the GitHub API path for scripted fallback PRs.
# Set to "github-api" locally when you want to test serverless-style PR creation without `gh`.
REFLEX_SCRIPTED_PR_PROVIDER=
REPLICAS_API_KEY=
REPLICAS_ENVIRONMENT_ID=
REPLICAS_WEBHOOK_SECRET=
