# Reflex environment (shared-contracts.md §8). Copy to .env.local and fill in.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# InsForge (Yash) — from `npx @insforge/cli current` / .insforge/project.json
INSFORGE_PROJECT_URL=https://<appkey>.<region>.insforge.app
INSFORGE_SERVICE_KEY=ik_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # full-access admin key, server-only

# Diagnosis model path (optional — diagnosis falls back to deterministic fixtures without it)
MODEL_API_KEY=

# Slack (Laurence)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Replicas + GitHub (Luke)
DEFAULT_GITHUB_REPO=https://github.com/yxshrk/electron
GITHUB_TOKEN=
REPLICAS_API_KEY=
REPLICAS_ENVIRONMENT_ID=
REPLICAS_WEBHOOK_SECRET=
