# Reflex environment (shared-contracts.md §8). Copy to .env.local and fill in. Server-side only.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Slack slice (Laurence): backend toggle — "mock" (default) uses the in-memory scripted backend;
# any other value hits the real /api/runs routes (needs InsForge below).
REFLEX_BACKEND=mock

# InsForge (Yash) — from `npx @insforge/cli current` / .insforge/project.json
INSFORGE_PROJECT_URL=https://<appkey>.<region>.insforge.app
INSFORGE_SERVICE_KEY=ik_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # full-access admin key, server-only

# Model access — InsForge provisions an OpenRouter key: `npx @insforge/cli ai setup --env-file .env.local`
# Used for frame vision (screen->text) and embeddings (pgvector codebase grounding).
# Without it, diagnosis falls back to deterministic fixtures and grounding returns empty.
OPENROUTER_API_KEY=sk-or-v1-...
REFLEX_VISION_MODEL=openai/gpt-4o-mini
REFLEX_EMBED_MODEL=openai/text-embedding-3-small

# Slack (Laurence)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Replicas + GitHub (Luke)
DEFAULT_GITHUB_REPO=https://github.com/yxshrk/electron
GITHUB_TOKEN=
REPLICAS_API_KEY=
REPLICAS_ENVIRONMENT_ID=
REPLICAS_WEBHOOK_SECRET=
