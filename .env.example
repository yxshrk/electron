# Reflex — shared env. Each owner maintains their block (shared-contracts.md §7).
# Copy to .env.local (gitignored) and fill in. Server-side only — never NEXT_PUBLIC_ a secret.

# --- Shared ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Backend toggle for the Slack slice: "mock" (default) uses the in-memory scripted backend;
# anything else hits Yash's real /api routes at NEXT_PUBLIC_APP_URL.
REFLEX_BACKEND=mock

# --- Laurence (Slack) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...        # only if using socket mode

# --- Yash (InsForge + model) ---
INSFORGE_PROJECT_URL=
INSFORGE_API_KEY=
MODEL_API_KEY=

# --- Luke (Replicas + GitHub) ---
REPLICAS_API_KEY=
REPLICAS_ENVIRONMENT_ID=
REPLICAS_WEBHOOK_SECRET=
GITHUB_REPO=yxshrk/electron
